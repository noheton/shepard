{
  "name": "shepard-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 8081",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --max-warnings 0",
    "fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --max-warnings 0 --fix"
  },
  "dependencies": {
    "@dlr-shepard/shepard-client": "2022.10.11",
    "bootstrap": "4.6.2",
    "bootstrap-vue": "2.22.0",
    "chart.js": "3.9.1",
    "jsoneditor": "9.9.2",
    "loglevel": "1.8.0",
    "mitt": "3.0.0",
    "nanoid": "4.0.0",
    "oidc-client": "1.11.5",
    "popper.js": "1.16.1",
    "portal-vue": "2.1.7",
    "vue": "2.7.13",
    "vue-chartjs": "4.1.2",
    "vue-router": "3.6.5",
    "vue2-helpers": "2.1.1",
    "vuex": "3.6.2",
    "vuex-oidc": "3.11.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.2.0",
    "@types/chart.js": "2.9.37",
    "@types/jsoneditor": "9.9.0",
    "@types/node": "16.11.68",
    "@vitejs/plugin-vue2": "2.0.0",
    "@volar/vue-typescript": "1.0.8",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "11.0.2",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.25.0",
    "eslint-plugin-vue": "9.6.0",
    "npm-run-all": "4.1.5",
    "prettier": "2.7.1",
    "prettier-plugin-organize-imports": "3.1.1",
    "typescript": "4.8.4",
    "vite": "3.1.8",
    "vue-tsc": "1.0.8"
  }
}
