{
  "name": "shepard-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@dlr-shepard/shepard-client": "2024.1.10",
    "@tiptap/extension-text-align": "2.1.16",
    "@tiptap/extension-underline": "2.1.16",
    "@tiptap/pm": "2.1.16",
    "@tiptap/starter-kit": "2.1.16",
    "@tiptap/vue-2": "2.1.16",
    "@vueuse/core": "10.7.2",
    "bootstrap": "4.6.2",
    "bootstrap-vue": "2.23.1",
    "chart.js": "4.4.1",
    "csv-parse": "5.5.3",
    "jsoneditor": "10.0.0",
    "loglevel": "1.8.1",
    "nanoid": "5.0.4",
    "oidc-client-ts": "2.4.0",
    "popper.js": "1.16.1",
    "portal-vue": "2.1.7",
    "vis-network": "9.1.9",
    "vue": "2.7.16",
    "vue-chartjs": "5.3.0",
    "vue-router": "3.6.5",
    "vue2-helpers": "2.1.1",
    "vuex": "3.6.2",
    "vuex-oidc": "4.0.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.7.0",
    "@tsconfig/node20": "20.1.2",
    "@types/chart.js": "2.9.41",
    "@types/jsoneditor": "9.9.5",
    "@types/node": "20.11.0",
    "@vitejs/plugin-vue2": "2.3.1",
    "@volar/vue-typescript": "1.6.5",
    "@vue/eslint-config-prettier": "9.0.0",
    "@vue/eslint-config-typescript": "12.0.0",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.56.0",
    "eslint-plugin-vue": "9.20.1",
    "npm-run-all2": "6.1.1",
    "prettier": "3.2.4",
    "prettier-plugin-organize-imports": "3.2.4",
    "sass": "1.64.2",
    "typescript": "4.9.5",
    "vite": "5.0.11",
    "vue-tsc": "1.8.27"
  }
}