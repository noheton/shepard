{
  "name": "shepard-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@dlr-shepard/shepard-client": "2023.9.4",
    "@vueuse/core": "10.4.1",
    "bootstrap": "4.6.2",
    "bootstrap-vue": "2.23.1",
    "chart.js": "4.4.0",
    "csv-parse": "5.5.0",
    "jsoneditor": "9.10.2",
    "loglevel": "1.8.1",
    "nanoid": "4.0.2",
    "oidc-client-ts": "2.2.5",
    "popper.js": "1.16.1",
    "portal-vue": "2.1.7",
    "vis-network": "9.1.6",
    "vue": "2.7.14",
    "vue-chartjs": "5.2.0",
    "vue-router": "3.6.5",
    "vue2-helpers": "2.1.1",
    "vuex": "3.6.2",
    "vuex-oidc": "4.0.2"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.3.3",
    "@tsconfig/node18": "18.2.1",
    "@types/chart.js": "2.9.38",
    "@types/jsoneditor": "9.9.0",
    "@types/node": "18.17.14",
    "@vitejs/plugin-vue2": "2.2.0",
    "@volar/vue-typescript": "1.6.5",
    "@vue/eslint-config-prettier": "8.0.0",
    "@vue/eslint-config-typescript": "11.0.3",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.48.0",
    "eslint-plugin-vue": "9.17.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.0.3",
    "prettier-plugin-organize-imports": "3.2.3",
    "sass": "1.64.2",
    "typescript": "4.9.5",
    "vite": "4.4.9",
    "vue-tsc": "1.8.8"
  }
}