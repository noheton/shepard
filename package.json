{
  "name": "shepard-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 8081",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --max-warnings 0",
    "fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore --max-warnings 0 --fix"
  },
  "dependencies": {
    "@dlr-shepard/shepard-client": "2022.12.12",
    "@vueuse/core": "9.10.0",
    "bootstrap": "4.6.2",
    "bootstrap-vue": "2.23.1",
    "chart.js": "4.1.2",
    "csv-parse": "5.3.3",
    "jsoneditor": "9.9.2",
    "loglevel": "1.8.1",
    "nanoid": "4.0.0",
    "oidc-client-ts": "2.2.0",
    "popper.js": "1.16.1",
    "portal-vue": "2.1.7",
    "vue": "2.7.14",
    "vue-chartjs": "5.2.0",
    "vue-router": "3.6.5",
    "vue2-helpers": "2.1.1",
    "vuex": "3.6.2",
    "vuex-oidc": "4.0.1"
  },
  "devDependencies": {
    "@rushstack/eslint-patch": "1.2.0",
    "@types/chart.js": "2.9.37",
    "@types/jsoneditor": "9.9.0",
    "@types/node": "18.11.18",
    "@vitejs/plugin-vue2": "2.2.0",
    "@volar/vue-typescript": "1.0.24",
    "@vue/eslint-config-prettier": "7.0.0",
    "@vue/eslint-config-typescript": "11.0.2",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.31.0",
    "eslint-plugin-vue": "9.9.0",
    "npm-run-all": "4.1.5",
    "prettier": "2.8.2",
    "prettier-plugin-organize-imports": "3.2.1",
    "sass": "1.57.1",
    "sass-loader": "13.2.0",
    "typescript": "4.9.4",
    "vite": "4.0.4",
    "vue-tsc": "1.0.24"
  }
}