# Integration test environment — copy to .env.integration and fill in values.
# Never commit .env.integration (it contains secrets).

# --- Target stack ---
# Base URL of the running shepard backend (no trailing slash).
BACKEND_URL=http://localhost:8080/shepard/api

# --- Auth: preferred path (fastest; skip Keycloak ROPC entirely) ---
# A long-lived API key minted by seed.py or shepard-admin.
# When set, KC_* variables below are ignored.
SHEPARD_API_KEY=

# --- Auth: fallback path (Keycloak ROPC — mirrors entrypoint.sh) ---
KC_URL=http://localhost:8082
KC_REALM=shepard-demo
KC_CLIENT_ID=frontend-dev
KC_ADMIN_USER=admin
KC_ADMIN_PASS=admin-demo
