{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: Release",
      "cwd": "${workspaceFolder}/scripts",
      "type": "debugpy",
      "request": "launch",
      "program": "shepard_scripts/main.py",
      "console": "integratedTerminal",
      "args": ["release", "./token.txt"]
    },
    {
      "preLaunchTask": "quarkus:dev (quarkend)",
      "type": "java",
      "request": "attach",
      "hostName": "localhost",
      "name": "Debug Quarkus application (quarkend)",
      "port": 5005
    }
  ]
}
