# home-showcase — MQTT collector environment template
#
# Copy this file to .env and fill in real values before running
# `docker compose --profile home-showcase up -d`. The .env file is
# read by docker-compose at runtime; nothing in this file is loaded
# automatically.
#
# ---- MQTT broker ---------------------------------------------------------
# The Home Assistant MQTT broker the collector subscribes to. Both port
# 1883 plain and 8883 TLS are common in HA installs; the demo broker
# at 192.168.1.60:1883 is plain MQTT inside a trusted LAN.
MQTT_HOST=192.168.1.60
MQTT_PORT=1883
MQTT_USER=mqtt
MQTT_PASSWORD=mqtt
# Toggle TLS + cert verification. Defaults: TLS off, no-verify if on.
MQTT_TLS=0
MQTT_TLS_VERIFY=0

# ---- shepard backend -----------------------------------------------------
# Points at the same backend the rest of the stack uses. SHEPARD_API_KEY
# is the value returned by the LUMEN seeder's admin bootstrap (see
# infrastructure/docker-compose.override.yml seeder service).
SHEPARD_API=http://backend:8080/shepard/api
SHEPARD_API_KEY=fill-me-with-the-admin-api-key

# ---- collector behaviour --------------------------------------------------
# How often the in-memory batch flushes to shepard. Default 30s — set
# lower for snappier dashboards at the cost of more API calls.
BATCH_INTERVAL_SEC=30
# Log verbosity. Set to DEBUG to see per-message ingestion.
LOG_LEVEL=INFO
