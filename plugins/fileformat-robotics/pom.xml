  <artifactId>shepard-plugin-fileformat-robotics</artifactId>
  <version>${revision}</version>
  <packaging>jar</packaging>

  <name>shepard plugin — fileformat robotics (RoboDK .rdk tier-1 text-scrape parser)</name>
  <description>
    Tier-1 text-scrape parser for RoboDK station files (.rdk) from the
    MFFD AFP robot cell at DLR ZLP Augsburg. Decompresses the zlib payload,
    walks length-prefixed UTF-16LE strings, and emits urn:shepard:rdk:*
    SemanticAnnotations on the parent FileReference. No DataObject or container
    creation; full kinematic-tree extraction deferred to RDK-PARSE-2.
  </description>
  <url>https://github.com/noheton/shepard</url>

  <organization>
    <name>DLR e.V.</name>
    <url>https://www.dlr.de</url>
