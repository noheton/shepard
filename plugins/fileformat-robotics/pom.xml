<?xml version="1.0" encoding="UTF-8"?>
<!--
  shepard-plugin-fileformat-robotics — RoboDK station (.rdk) tier-1 parser (Tier-1)

  Parses RoboDK station files from the MFFD AFP robot cell at DLR ZLP Augsburg.
  Decompresses the zlib payload, walks length-prefixed UTF-16LE string records,
  classifies each via predicate-specific regexes, and emits urn:shepard:rdk:*
  SemanticAnnotations on the parent FileReference:
    appVersion, platform, programSource, cadRef, stepRef, apiEndpoint,
    robotController, companionSpatialAnalyzer (paired .xit Spatial Analyzer ref).

  Tier-1 scope (RDK-PARSE-1): text-scrape only; no kinematic-tree extraction
  (deferred to RDK-PARSE-2 via RoboDK Python API sidecar).

  Why Tier-1: the plugin implements PluginManifest (backend SPI), which requires
  the backend as a compile-time provided dependency.

  Build order:
    $ cd backend && mvn -DnoPlugins -DskipTests -Dquarkus.build.skip=true install
    $ cd plugins/fileformat-robotics && mvn -DnoPlugins -DskipTests install
    $ cd backend && mvn package

  See plugins/fileformat-robotics/docs/reference.md for the operator runbook.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
