{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "uid": "shepard-overview",
  "title": "shepard — Overview",
  "tags": ["shepard", "overview"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "HTTP",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP requests / sec (by status)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{job=\"shepard-metrics\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      },
      "options": { "legend": { "showLegend": true } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP latency p95 / p99 (seconds)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"shepard-metrics\"}[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{job=\"shepard-metrics\"}[5m])))",
          "legendFormat": "p99",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "row",
      "title": "JVM",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "JVM heap used (bytes)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{area=\"heap\",job=\"shepard-metrics\"}) by (id)",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "JVM threads",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"shepard-metrics\"}",
          "legendFormat": "live",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"shepard-metrics\"}",
          "legendFormat": "daemon",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "GC pause time (seconds / minute)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "expr": "sum by (action) (rate(jvm_gc_pause_seconds_sum{job=\"shepard-metrics\"}[1m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 20,
      "type": "row",
      "title": "Databases",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "Hibernate session metrics (events / sec)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "targets": [
        {
          "expr": "sum by (__name__) (rate({__name__=~\"hibernate_sessions_(opened|closed)_total\",job=\"shepard-metrics\"}[1m]))",
          "legendFormat": "{{__name__}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "MongoDB command duration p95 (seconds)",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, command_name) (rate(mongodb_driver_commands_seconds_bucket{job=\"shepard-metrics\"}[5m])))",
          "legendFormat": "{{command_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 30,
      "type": "row",
      "title": "Permissions cache",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }
    },
    {
      "id": 31,
      "type": "stat",
      "title": "Permissions cache hit ratio",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "targets": [
        {
          "expr": "sum(rate(cache_gets_total{cache=\"permissions-service-cache\",result=\"hit\",job=\"shepard-metrics\"}[5m])) / sum(rate(cache_gets_total{cache=\"permissions-service-cache\",job=\"shepard-metrics\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1 },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "id": 32,
      "type": "timeseries",
      "title": "Permissions cache size",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "targets": [
        {
          "expr": "cache_size{cache=\"permissions-service-cache\",job=\"shepard-metrics\"}",
          "legendFormat": "size",
          "refId": "A"
        }
      ]
    }
  ]
}
