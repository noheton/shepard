BACKEND_URL="Backend URL"
NEO4J_PW="secret"
OIDC_AUTHORITY="Keycloak realm URL"
OIDC_PUBLIC="Keycloak public key"
OIDC_ROLE="Optional role to restrict access"
CLIENT_ID="Frontend client ID"

# MongoDB Setup
MONGO_ROOT_USERNAME="mongo"
MONGO_ROOT_PASSWORD="secret"

MONGO_DATABASE="database"
MONGO_USERNAME="mongo_user"
MONGO_PASSWORD="secret"

# Grafana Setup
GRAFANA_ADMIN_USERNAME="shepard"
GRAFANA_ADMIN_PASSWORD="secret"

# Postgres Setup
POSTGRES_DB="postgres"
## These are the credentials for the postgres admin account
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
## These are the credentials for the shepard user account
POSTGRES_SHEPARD_USER="shepard"
POSTGRES_SHEPARD_USER_PW="shepard_secret"

# Only required until migration in https://gitlab.com/dlr-shepard/shepard/-/merge_requests/389#migration-instructions is done
INFLUX_PW="secret"

# Required for experimental use

FRONTEND_URL="Frontend URL"
FRONTEND_AUTH_SECRET="Frontend auth secret"
SESSION_REFRESH_INTERVAL="30000" # frontend session refresh interval in ms (defaults to 30secs)

# InfluxDb migration mode
SHEPARD_MIGRATION_MODE_ENABLED="true"

# Spatial Data mode
SHEPARD_SPATIAL_DATA_ENABLED="false"

# Enable automatic conversion of integer values to double for time series with type double.
# For more information see https://gitlab.com/dlr-shepard/shepard/-/merge_requests/717
SHEPARD_AUTOCONVERT_INT="false"

# shepard-plugin-jupyter (J1e) — JupyterHub sidecar env vars.
# Only consumed when COMPOSE_PROFILES includes `jupyter`.
# See plugins/jupyter/docs/install.md for the full operator runbook.
JUPYTERHUB_KEYCLOAK_CLIENT_ID="jupyterhub"
JUPYTERHUB_KEYCLOAK_CLIENT_SECRET=""
JUPYTERHUB_PUBLIC_URL="https://shepard.example.org/jupyterhub"
# Optional override; defaults to jupyter/scipy-notebook:python-3.11 if unset.
JUPYTERHUB_SINGLEUSER_IMAGE=""
# URL the kernel uses to call back into shepard; defaults to the compose
# service name when unset.
SHEPARD_BACKEND_URL="http://backend:8080"

# Configure docker profiles to enable experimental features.
# Add `jupyter` to enable the shepard-plugin-jupyter sidecar.
COMPOSE_PROFILES=
