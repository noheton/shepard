# Caddyfile for shepard behind Zoraxy (TLS terminated upstream)
# Zoraxy routes:
#   https://shepard.nuclide.systems      → 192.168.1.49:80   → this Caddy → frontend:3000
#   https://shepard-api.nuclide.systems  → 192.168.1.49:8080 → backend directly
#   https://shepard-auth.nuclide.systems → 192.168.1.49:8082 → keycloak directly
#   https://shepard-ntfy.nuclide.systems → 192.168.1.49:8085 → ntfy directly
#
# All vhosts are served over plain HTTP; Zoraxy provides TLS.

{
	auto_https off
}

:80 {
	reverse_proxy frontend:3000
}
