# Quarkus configuration for development and running the tests

# Public key of the OIDC provider
# This can be set to a fake value for the tests but must be a valid value to run the frontend
OIDC_

# Link to the OIDC provider (including realm)
# This can be set to a fake value for the tests but must be a valid value to run the frontend
OIDC_AUTHORITY=http://localhost:8082/realms/master/

QUARKUS_MONGODB_CONNECTION_STRING=mongodb://mongo:shepard@localhost:27017

QUARKUS_DATASOURCE_JDBC_URL: jdbc:postgresql://localhost:5432/postgres
QUARKUS_DATASOURCE_USERNAME: shepard
QUARKUS_DATASOURCE_PASSWORD: shepard_secret

QUARKUS_DATASOURCE_SPATIAL_JDBC_URL: jdbc:postgresql://localhost:5433/postgres
QUARKUS_DATASOURCE_SPATIAL_USERNAME: shepard
QUARKUS_DATASOURCE_SPATIAL_PASSWORD: shepard_secret

NEO4J_HOST: localhost:7687
NEO4J_USERNAME: neo4j
NEO4J_PASSWORD: shepardshepard

SHEPARD_SPATIAL_DATA_ENABLED: true

POSTGRES_DB: postgres
POSTGRES_USER: shepard
POSTGRES_PASSWORD: shepard_secret
