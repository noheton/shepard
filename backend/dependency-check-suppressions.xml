  <!-- ===================================================================
       OWASP-SUPP-008: Google protobuf-java 4.35.0 (CVE-2026-0994, 7.5)
       (re-targeted from 3.25.5; QUARKUS-3.37 tree shifted the version + source)
       =================================================================== -->
  <!--
    CVE-2026-0994 is a JSON-recursion denial-of-service in protobuf's JSON parser
    (deeply-nested google.protobuf.Any messages bypass the recursion-depth cap in
    ParseDict / JsonFormat). In the post-migration tree protobuf-java 4.35.0 is a
    transitive dependency of Apache Jena (jena-arq → protobuf-java), used only for
    Jena's internal RDF/index serialisation of trusted, server-constructed data.
    shepard exposes no protobuf wire or protobuf-JSON endpoint and never parses
    untrusted protobuf/JSON input through this path, so the vulnerable JSON-recursion
    codepath is unreachable. Accepted residual risk pending an upstream Jena/protobuf
    bump. OWASP-SUPP-008.
  -->
  <suppress until="2026-12-31">
    <notes>CVE-2026-0994 (CVSS 7.5): protobuf-java 4.35.0 JSON-recursion DoS (nested Any
    in ParseDict/JsonFormat). Transitive via Apache Jena (jena-arq); used only for Jena's
    internal RDF/index serialisation of trusted server-side data. shepard exposes no
    protobuf or protobuf-JSON endpoint and parses no untrusted protobuf input; the
    vulnerable codepath is unreachable. OWASP-SUPP-008.</notes>
    <packageUrl regex="true">^pkg:maven/com\.google\.protobuf/protobuf-java@4\.35\.0$</packageUrl>
    <cve>CVE-2026-0994</cve>
  </suppress>

