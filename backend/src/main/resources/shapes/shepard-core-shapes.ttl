# shepard-core-shapes.ttl — Base SHACL shapes for the core Shepard types.
#
# These shapes describe what a valid Collection, DataObject, and
# Container instance looks like. They are the *minimal* contract every
# domain shape must layer on top of via sh:and / sh:node composition.
#
# Aligned per aidocs/semantics/96 §3.1:
#   shepard:Collection ⊑ iao:DataSet ⊑ bfo:Continuant
#   shepard:DataObject ⊑ iao:DataItem ⊑ bfo:Continuant
#   shepard:Container  ⊑ bfo:GenericallyDependentContinuant
#
# Cited from aidocs/semantics/95 Part 4 (named individuals) and
# Part 8 (graph relationship) — these shapes target the same classes
# that the V2 API exposes; the shape acts as the IO contract.

@prefix shepard: <http://semantics.dlr.de/shepard-upper#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix prov:    <http://www.w3.org/ns/prov#> .
@prefix iao:     <http://purl.obolibrary.org/obo/IAO_> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# ─── Core class declarations (lightweight, alignment-only) ─────────────

shepard:Collection a owl:Class ;
    rdfs:subClassOf iao:DataSet ;
    rdfs:label "Shepard Collection"@en ;
    rdfs:comment "Top-level container of related DataObjects."@en .

shepard:DataObject a owl:Class ;
    rdfs:subClassOf iao:DataItem ;
    rdfs:label "Shepard DataObject"@en .

shepard:Container a owl:Class ;
    rdfs:label "Shepard Container (abstract)"@en ;
    rdfs:comment "Abstract base class for payload containers."@en .

shepard:TimeseriesContainer    rdfs:subClassOf shepard:Container .
shepard:FileContainer          rdfs:subClassOf shepard:Container .
shepard:StructuredDataContainer rdfs:subClassOf shepard:Container .

# ─── shepard:CollectionShape ───────────────────────────────────────────

shepard:CollectionShape a sh:NodeShape ;
    sh:targetClass shepard:Collection ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "Collection shape"@en ;
    rdfs:comment "Minimal contract for a Collection instance; see aidocs/95 Part 1."@en ;

    sh:property [
        sh:path    dcterms:created ;
        sh:datatype xsd:dateTime ;
        sh:maxCount 1 ;
        sh:name    "Created at"@en ;
        sh:order   30
    ] ;
    sh:property [
        sh:path    dcterms:description ;
        sh:datatype xsd:string ;
        sh:maxCount 1 ;
        sh:name    "Description"@en ;
        sh:order   20
    ] ;
    sh:property [
        sh:path    dcterms:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 1 ;
        sh:name    "Title"@en ;
        sh:order   10 ;
        sh:message "A Collection requires a non-empty title."@en
    ] .

# ─── shepard:DataObjectShape ───────────────────────────────────────────

shepard:DataObjectShape a sh:NodeShape ;
    sh:targetClass shepard:DataObject ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "DataObject shape"@en ;
    rdfs:comment "Minimal contract for a DataObject instance."@en ;

    sh:property [
        sh:path    dcterms:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:minLength 1 ;
        sh:name    "Title"@en ;
        sh:order   10 ;
        sh:message "A DataObject requires a non-empty title."@en
    ] ;
    sh:property [
        sh:path    shepard:status ;
        sh:datatype xsd:string ;
        sh:in      ( "DRAFT" "IN_REVIEW" "READY" "PUBLISHED"
                     "ARCHIVED" "NCR_OPEN" "REJECTED" ) ;
        sh:maxCount 1 ;
        sh:name    "Status"@en ;
        sh:order   20 ;
        sh:message "Status must be one of the lifecycle vocabulary terms."@en
    ] ;
    sh:property [
        sh:path    prov:wasInformedBy ;
        sh:class   shepard:DataObject ;
        sh:nodeKind sh:IRI ;
        sh:name    "Informed by (predecessor)"@en ;
        sh:order   40
    ] ;
    sh:property [
        sh:path    prov:wasGeneratedBy ;
        sh:class   prov:Activity ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:name    "Generated by (Activity)"@en ;
        sh:order   30
    ] .

# ─── shepard:ContainerShape (abstract) ─────────────────────────────────

shepard:ContainerShape a sh:NodeShape ;
    sh:targetClass shepard:Container ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "Container shape (abstract)"@en ;
    rdfs:comment "Abstract shape — every concrete container kind extends this with sh:and."@en ;

    sh:property [
        sh:path    dcterms:title ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name    "Title"@en ;
        sh:order   10
    ] ;
    sh:property [
        sh:path    shepard:storageBackend ;
        sh:datatype xsd:string ;
        sh:in      ( "influxdb" "mongodb" "minio" "postgres" "hdf5" "filesystem" ) ;
        sh:maxCount 1 ;
        sh:name    "Physical storage backend"@en ;
        sh:order   20 ;
        sh:message "storageBackend must name a known storage adapter."@en
    ] .

# ─── shepard:TimeseriesContainerShape ──────────────────────────────────

shepard:TimeseriesContainerShape a sh:NodeShape ;
    sh:targetClass shepard:TimeseriesContainer ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "Timeseries container shape"@en ;
    rdfs:comment "Container holding time-indexed numeric channels. Per aidocs/87 — channel identity migrates to single appId."@en ;
    sh:and ( shepard:ContainerShape ) ;

    sh:property [
        sh:path    shepard:channelCount ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxCount 1 ;
        sh:name    "Channel count"@en ;
        sh:order   30
    ] ;
    sh:property [
        sh:path    shepard:sampleRateHz ;
        sh:datatype xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxCount 1 ;
        sh:name    "Nominal sample rate (Hz)"@en ;
        sh:order   40
    ] .

# ─── shepard:FileContainerShape ────────────────────────────────────────

shepard:FileContainerShape a sh:NodeShape ;
    sh:targetClass shepard:FileContainer ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "File container shape"@en ;
    rdfs:comment "Container holding opaque files in object storage."@en ;
    sh:and ( shepard:ContainerShape ) ;

    sh:property [
        sh:path    shepard:fileCount ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxCount 1 ;
        sh:name    "File count"@en ;
        sh:order   30
    ] ;
    sh:property [
        sh:path    shepard:totalSizeBytes ;
        sh:datatype xsd:long ;
        sh:minInclusive 0 ;
        sh:maxCount 1 ;
        sh:name    "Total size (bytes)"@en ;
        sh:order   40
    ] .

# ─── shepard:StructuredDataContainerShape ──────────────────────────────

shepard:StructuredDataContainerShape a sh:NodeShape ;
    sh:targetClass shepard:StructuredDataContainer ;
    dcterms:hasVersion "1.0.0" ;
    rdfs:label "Structured data container shape"@en ;
    rdfs:comment "Container holding JSON / BSON documents (MongoDB-backed by default)."@en ;
    sh:and ( shepard:ContainerShape ) ;

    sh:property [
        sh:path    shepard:documentCount ;
        sh:datatype xsd:integer ;
        sh:minInclusive 0 ;
        sh:maxCount 1 ;
        sh:name    "Document count"@en ;
        sh:order   30
    ] ;
    sh:property [
        sh:path    shepard:schemaIri ;
        sh:nodeKind sh:IRI ;
        sh:maxCount 1 ;
        sh:name    "JSON schema IRI"@en ;
        sh:order   40
    ] .
