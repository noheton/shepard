                                                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                               owl:onProperty om-2:hasUnit ;
                                                                                               owl:allValuesFrom om-2:StressUnit
                                                                                             ]
                                                                         ] ;
                                                         rdfs:comment "Mechanical property marking the transition from elastic to irreversible plastic deformation.e"@en ;
