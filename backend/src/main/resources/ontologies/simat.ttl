###  https://w3id.org/simat/humidity
<https://w3id.org/simat/humidity> rdf:type owl:Class ;
                                                    rdfs:subClassOf om-2:Quantity ;
                                                    rdfs:label "Humidity"@en .


###  http://semantics.dlr.de/SimulationOntology#FiniteElement
<http://semantics.dlr.de/SimulationOntology#FiniteElement> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://w3id.org/polymat/DigitalData> ;
                                                           rdfs:comment "Connection between characteristic points or nodes of an FEM model which uses a set of equations (shape functions) to calculate the internal state within this element."@en ;
                                                           rdfs:label "Finite element"@en .


###  http://semantics.dlr.de/SimulationOntology#FiniteElementMesh
<http://semantics.dlr.de/SimulationOntology#FiniteElementMesh> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#FiniteElementModel> ;
                                                               rdfs:comment "Numerical representation of a given problem or bodies using set of nodes and finite elements for its geometrical representation"@en ;
                                                               rdfs:label "Finite element mesh"@en .


###  http://semantics.dlr.de/SimulationOntology#FiniteElementModel
<http://semantics.dlr.de/SimulationOntology#FiniteElementModel> rdf:type owl:Class ;
                                                                rdfs:subClassOf <https://w3id.org/polymat/DigitalData> ;
                                                                rdfs:comment "Numerical representation of a real problem that contains boundary conditions for the model calculation and parameters for the computational methods used."@en ;
                                                                rdfs:label "Finite element model"@en .


###  http://semantics.dlr.de/SimulationOntology#FiniteElementSimulation
<http://semantics.dlr.de/SimulationOntology#FiniteElementSimulation> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#NumericalSimulation> ;
                                                                     rdfs:comment """A method for numerically solving differential equations arising in engineering and mathematical modeling.
(https://en.wikipedia.org/wiki/Finite_element_method)"""@en ;
                                                                     rdfs:label "Finite Element simulation"@en .


###  http://semantics.dlr.de/SimulationOntology#FiniteElementSolver
<http://semantics.dlr.de/SimulationOntology#FiniteElementSolver> rdf:type owl:Class ;
                                                                 rdfs:subClassOf <https://w3id.org/polymat/Software> ;
                                                                 rdfs:comment "A computational algorithm that are used to solve the matrix equations of a finite element model."@en ;
                                                                 rdfs:label "Finite element solver"@en .


###  http://semantics.dlr.de/SimulationOntology#HexahedronSolidElement
<http://semantics.dlr.de/SimulationOntology#HexahedronSolidElement> rdf:type owl:Class ;
                                                                    rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#SolidElement> ;
                                                                    rdfs:comment "Solid element possessing 8 nodes in a hexahedral pattern."@en ;
                                                                    rdfs:label "Hexahedron solid element"@en .


###  http://semantics.dlr.de/SimulationOntology#MaterialModel
<http://semantics.dlr.de/SimulationOntology#MaterialModel> rdf:type owl:Class ;
                                                           rdfs:subClassOf <https://w3id.org/polymat/DigitalData> ;
                                                           rdfs:comment """A mathematical representation that describes the expected behavior of a material in response to applied loads, incorporating relationships such as stress and strain.
(https://www.sciencedirect.com/topics/engineering/material-model)"""@en ;
                                                           rdfs:label "Material model"@en .


###  http://semantics.dlr.de/SimulationOntology#Node
<http://semantics.dlr.de/SimulationOntology#Node> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/polymat/DigitalData> ;
                                                  rdfs:comment """A discrete point in a mesh that serve as the locations for calculating approximate displacements and other quantities in finite element and finite difference methods, with the nodal point patterns being identical in both approaches.
(https://www.sciencedirect.com/topics/engineering/finite-element-node)"""@en ;
                                                  rdfs:label "Node"@en .


###  http://semantics.dlr.de/SimulationOntology#NumericalSimulation
<http://semantics.dlr.de/SimulationOntology#NumericalSimulation> rdf:type owl:Class ;
                                                                 rdfs:subClassOf prov:Activity ;
                                                                 rdfs:comment "A calculation that is run on a computer following a program that implements a mathematical model for a physical system."@en ;
                                                                 rdfs:label "Numerical simulation"@en .


###  http://semantics.dlr.de/SimulationOntology#PentahedronSolidELement
<http://semantics.dlr.de/SimulationOntology#PentahedronSolidELement> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#SolidElement> ;
                                                                     rdfs:comment "Solid element possessing 6 nodes in a pentahedral pattern."@en ;
                                                                     rdfs:label "Pentahedron element"@en .


###  http://semantics.dlr.de/SimulationOntology#QuadraticThinShellElement
<http://semantics.dlr.de/SimulationOntology#QuadraticThinShellElement> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#ThinShellElement> ;
                                                                       owl:disjointWith <http://semantics.dlr.de/SimulationOntology#TriangularThinShellElement> ;
                                                                       rdfs:comment "Thin shell finite element with 4 nodes."@en ;
                                                                       rdfs:label "Quadratic thin shell element"@en .


###  http://semantics.dlr.de/SimulationOntology#SolidElement
<http://semantics.dlr.de/SimulationOntology#SolidElement> rdf:type owl:Class ;
                                                          rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#FiniteElement> ;
                                                          rdfs:comment "Finite element for the calculation of the 3D material state."@en ;
                                                          rdfs:label "Solid element"@en .


###  http://semantics.dlr.de/SimulationOntology#TetrahedronSolidElement
<http://semantics.dlr.de/SimulationOntology#TetrahedronSolidElement> rdf:type owl:Class ;
                                                                     rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#SolidElement> ;
                                                                     rdfs:comment "Solid element possessing 4 nodes in a tetrahedral pattern."@en ;
                                                                     rdfs:label "Tetrahedron element"@en .


###  http://semantics.dlr.de/SimulationOntology#ThickShellElement
<http://semantics.dlr.de/SimulationOntology#ThickShellElement> rdf:type owl:Class ;
                                                               rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#FiniteElement> ;
                                                               rdfs:comment "Finite element for the calculation of the 3D material state using simplification in thickness direction of the element to reduce the computing time."@en ;
                                                               rdfs:label "Thick shell element"@en .


###  http://semantics.dlr.de/SimulationOntology#ThinShellElement
<http://semantics.dlr.de/SimulationOntology#ThinShellElement> rdf:type owl:Class ;
                                                              rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#FiniteElement> ;
                                                              rdfs:comment "2D finite element for the calculation of the in-plane 2D material state which uses simplifications in thickness direction."@en ;
                                                              rdfs:label "Thin shell element"@en .


###  http://semantics.dlr.de/SimulationOntology#TriangularThinShellElement
<http://semantics.dlr.de/SimulationOntology#TriangularThinShellElement> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <http://semantics.dlr.de/SimulationOntology#ThinShellElement> ;
                                                                        rdfs:comment "Shell finite element with 3 nodes."@en ;
                                                                        rdfs:label "Triangular thin shell element"@en .


###  http://www.co-ode.org/ontologies/ont.owl#DigitalImageCorrelation
<http://www.co-ode.org/ontologies/ont.owl#DigitalImageCorrelation> rdf:type owl:Class ;
                                                                   rdfs:subClassOf <https://w3id.org/polymat/Analysis> ;
                                                                   rdfs:label "Digital Image Correlation"@en .


