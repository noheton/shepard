om-2:CelsiusTemperatureUnit rdf:type owl:Class ;
                            rdfs:subClassOf om-2:TemperatureUnit ;
                            rdfs:label "Celsius temperature unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Circumference
om-2:Circumference rdf:type owl:Class ;
                   rdfs:subClassOf om-2:Length ;
                   om-2:symbol "C" ;
                   rdfs:label "circumference"@en ,
                              "omtrek"@nl ,
                              "圆周"@zh .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/ColourIndex
om-2:ColourIndex rdf:type owl:Class ;
                 rdfs:subClassOf om-2:Quantity ;
                 rdfs:comment "The difference between the apparent magnitude of a star at two different wavelengths (always the shorter-wavelength magnitude minus the longer-wavelength magnitude) to give a quantification of the star's colour. The magnitude of an object at different wavelengths are measured by using different filters before the detector. Often the Johnson system with UBV passbands are used. Other passbands may also be used (for instance g-r)."@en ;
                 rdfs:label "colour index"@en ,
                            "kleurindex"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Cost
om-2:Cost rdf:type owl:Class ;
          rdfs:subClassOf om-2:AmountOfMoney ;
          rdfs:label "cost"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Date
om-2:Date rdf:type owl:Class ;
          rdfs:subClassOf om-2:Time ;
          rdfs:label "date"@en ,
                     "datum"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Density
om-2:Density rdf:type owl:Class ;
             rdfs:subClassOf om-2:Quantity ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty om-2:hasValue ;
                               owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                   owl:onProperty om-2:hasUnit ;
                                                   owl:allValuesFrom om-2:DensityUnit
                                                 ]
                             ] ;
             om-2:alternativeLabel "concentration (w/v)"@en ,
                                   "mass density"@en ,
                                   "soortelijke massa"@nl ;
             om-2:symbol "ρ" ;
             rdfs:comment "Density is the concentration of matter. It is a derived quantity in the International System of Units. Density is mass divided by volume."@en ;
             rdfs:label "density"@en ,
                        "dichtheid"@nl ,
                        "密度"@zh .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/DensityUnit
om-2:DensityUnit rdf:type owl:Class ;
                 rdfs:subClassOf om-2:Unit ;
                 rdfs:label "density unit"@en .


