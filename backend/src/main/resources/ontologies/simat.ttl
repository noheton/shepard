                                                          rdfs:subClassOf <https://w3id.org/simat/Metals> ;
                                                          om-2:alternativeLabel "Al"@en ;
                                                          rdfs:comment """An aluminium alloy or aluminum alloy is an alloy in which aluminium is the predominant metal. 
(https://en.wikipedia.org/wiki/Aluminium_alloy)"""@en ;
                                                          rdfs:label "Aluminium"@en .


###  https://w3id.org/simat/AmorphousThermoplast
<https://w3id.org/simat/AmorphousThermoplast> rdf:type owl:Class ;
                                                                rdfs:subClassOf <https://w3id.org/simat/Thermoplastic> ;
                                                                rdfs:comment """Amorphous polymers are defined as materials that lack a defined geometrical shape and have a random arrangement of molecular chains, resulting in properties such as brittleness, transparency, and higher impact resistance. They do not have a sharp melting point and soften gradually over a range of temperatures, with glass transition temperature being a key characteristic.
(https://www.sciencedirect.com/topics/engineering/amorphous-polymer)"""@en ;
                                                                rdfs:label "Amorphous thermoplast"@en .


###  https://w3id.org/simat/AnisotropicMaterialBehaviour
<https://w3id.org/simat/AnisotropicMaterialBehaviour> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <https://w3id.org/simat/MechanicalMaterialBehaviour> ;
                                                                        rdfs:comment "Structural property of non-uniformity of a material in different directions, as opposed to isotropy. An anisotropic object or pattern has properties that differ according to direction of measurement."@en ;
                                                                        rdfs:label "Anisotropic material behaviour"@en .


