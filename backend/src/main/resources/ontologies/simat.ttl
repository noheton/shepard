               rdfs:subClassOf om-2:Length ;
               om-2:alternativeSymbol "δ" ;
               om-2:symbol "d" ;
               rdfs:comment "The smallest dimension of a flat object, usually a mean value of several measurements"@en ;
               rdfs:label "dikte"@nl ,
                          "thickness"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Time
om-2:Time rdf:type owl:Class ;
          rdfs:subClassOf om-2:Quantity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty om-2:hasValue ;
                            owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                owl:onProperty om-2:hasUnit ;
                                                owl:allValuesFrom om-2:TimeUnit
                                              ]
                          ] ;
          om-2:symbol "t" ;
          rdfs:comment "Time is a base quantity in the International System of Units and other systems of units. It is measured by numbers of repetitions of cyclical events."@en ;
          rdfs:label "tijd"@nl ,
                     "time"@en ,
                     "时间"@zh .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/TimeUnit
