                                                          owl:allValuesFrom om-2:VolumeFractionUnit
                                                        ]
                                    ] ;
                    om-2:alternativeLabel "concentration (v/v)"@en ;
                    om-2:symbol "φ" ;
                    rdfs:label "volume fraction"@en ,
                               "volumefractie"@nl .


