###  http://www.ontology-of-units-of-measure.org/resource/om-2/Force
om-2:Force rdf:type owl:Class ;
           rdfs:subClassOf om-2:Quantity ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty om-2:hasValue ;
                             owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                 owl:onProperty om-2:hasUnit ;
                                                 owl:allValuesFrom om-2:ForceUnit
                                               ]
                           ] ;
           om-2:symbol "F" ;
           rdfs:comment "Force is the extent to which an object with mass can be caused to accelerate. It is a derived quantity in the International System of Units. Force is mass times acceleration."@en ;
           rdfs:label "force"@en ,
                      "kracht"@nl ,
                      "力"@zh .


