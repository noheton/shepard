###  http://www.ontology-of-units-of-measure.org/resource/om-2/Acceleration
om-2:Acceleration rdf:type owl:Class ;
                  rdfs:subClassOf om-2:Quantity ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty om-2:hasValue ;
                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                        owl:onProperty om-2:hasUnit ;
                                                        owl:allValuesFrom om-2:AccelerationUnit
                                                      ]
                                  ] ;
                  om-2:alternativeLabel "acceleratie"@nl ;
                  om-2:symbol "a" ;
                  rdfs:label "acceleration"@en ,
                             "versnelling"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AccelerationUnit
om-2:AccelerationUnit rdf:type owl:Class ;
                      rdfs:subClassOf om-2:Unit ;
                      rdfs:label "acceleration unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AmountOfMoney
om-2:AmountOfMoney rdf:type owl:Class ;
                   rdfs:subClassOf om-2:Quantity ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty om-2:hasValue ;
                                     owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                         owl:onProperty om-2:hasUnit ;
                                                         owl:allValuesFrom om-2:AmountOfMoneyUnit
                                                       ]
                                   ] ;
                   rdfs:label "amount of money"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AmountOfMoneyUnit
om-2:AmountOfMoneyUnit rdf:type owl:Class ;
                       rdfs:subClassOf om-2:Unit ;
                       rdfs:label "amount of money unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Amplitude
om-2:Amplitude rdf:type owl:Class ;
               rdfs:subClassOf om-2:Quantity ;
               rdfs:comment "The difference between the maximum and minimum magnitudes of a variable star, i.e., the total range of its brightness."@en ;
               rdfs:label "amplitude"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Angle
om-2:Angle rdf:type owl:Class ;
           rdfs:subClassOf om-2:Quantity ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty om-2:hasValue ;
                             owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                 owl:onProperty om-2:hasUnit ;
                                                 owl:allValuesFrom om-2:AngleUnit
                                               ]
                           ] ;
           om-2:alternativeLabel "plane angle"@en ;
           om-2:alternativeSymbol "β" ,
                                  "γ" ,
                                  "θ" ,
                                  "φ" ;
           om-2:symbol "α" ;
           rdfs:comment "Angle is the ratio between an arc and its radius."@en ;
           rdfs:label "angle"@en ,
                      "hoek"@nl ,
                      "角度"@zh .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AngleUnit
om-2:AngleUnit rdf:type owl:Class ;
               rdfs:subClassOf om-2:Unit ;
               rdfs:label "angle unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/Area
om-2:Area rdf:type owl:Class ;
          rdfs:subClassOf om-2:Quantity ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty om-2:hasValue ;
                            owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                owl:onProperty om-2:hasUnit ;
                                                owl:allValuesFrom om-2:AreaUnit
                                              ]
                          ] ;
          om-2:alternativeLabel "oppervlak"@nl ;
          om-2:alternativeSymbol "S" ;
          om-2:symbol "A" ;
          rdfs:comment "Area expresses the two-dimensional size of a defined part of a surface, typically a region bounded by a closed curve. It is a derived quantity in the International System of Units. Area is length squared."@en ;
          rdfs:label "area"@en ,
                     "oppervlakte"@nl ,
                     "面积"@zh .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AreaDensity
om-2:AreaDensity rdf:type owl:Class ;
                 rdfs:subClassOf om-2:Quantity ;
                 rdfs:label "area density"@en ,
                            "oppervlaktedichtheid"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AreaFraction
om-2:AreaFraction rdf:type owl:Class ;
                  rdfs:subClassOf om-2:Quantity ;
                  rdfs:label "area fraction"@en ,
                             "oppervlaktefractie"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/AreaUnit
om-2:AreaUnit rdf:type owl:Class ;
              rdfs:subClassOf om-2:Unit ;
              rdfs:label "area unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/BulkModulus
om-2:BulkModulus rdf:type owl:Class ;
                 rdfs:subClassOf om-2:DynamicModulus ;
                 om-2:alternativeSymbol "κ" ;
                 om-2:symbol "K" ;
                 rdfs:comment "Bulk modulus is a substance's resistance to uniform compression."@en ;
                 rdfs:label "bulk modulus"@en ,
                            "compressiemodulus"@nl .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/CelsiusTemperature
om-2:CelsiusTemperature rdf:type owl:Class ;
                        rdfs:subClassOf om-2:Temperature ;
                        om-2:alternativeSymbol "θ" ;
                        om-2:symbol "t" ;
                        rdfs:label "Celsius temperature"@en ,
                                   "Celsiustemperatuur"@nl .


