@base <https://w3id.org/simat/> .

<https://w3id.org/simat/> rdf:type owl:Ontology ;
                                                              dc:contributor "German Aerospace Center, Institute for Structures and Design"@en ;
                                                              dc:creator "Mathieu Vinot, Institute of Structures and Design, German Aerospace Center (DLR), ORCID: 0000-0003-3394-5142"@en ;
                                                              dc:description "This ontology models concepts that are important to reasearchers in engineering material science."@en ;
                                                              terms:abstract "The simat ontology is a domain ontology to describe and represent scientific terminology relevant to experimental and numerical material mechanical characterization. It enables semantic description of knowledge and facilitates formal documentation of scientific processes."@en ;
                                                              terms:licence "https://spdx.org/licenses/CC-BY-4.0.html" ;
                                                              terms:title "The Simulation of Material Testing Ontology"^^rdfs:Literal ;
                                                              vann:preferredNamespacePrefix "simat"@en ;
                                                              vann:preferredNamespaceUri "https://w3id.org/simat/"@en ;
                                                              rdfs:label "Ontology for material testing and simulation"@en ;
                                                              owl:versionInfo "1.0.0" .

