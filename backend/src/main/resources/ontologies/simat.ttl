om-2:TemperatureUnit rdf:type owl:Class ;
                     rdfs:subClassOf om-2:Unit ;
                     rdfs:label "temperature unit"@en .


###  http://www.ontology-of-units-of-measure.org/resource/om-2/ThermalConductivity
om-2:ThermalConductivity rdf:type owl:Class ;
                         rdfs:subClassOf om-2:Quantity ,
                                         [ rdf:type owl:Restriction ;
                                           owl:onProperty om-2:hasValue ;
                                           owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                               owl:onProperty om-2:hasUnit ;
                                                               owl:allValuesFrom om-2:ThermalConductivityUnit
                                                             ]
                                         ] ;
                         om-2:alternativeSymbol "K" ,
                                                "k" ,
                                                "λ" ;
                         om-2:symbol "κ" ;
                         rdfs:comment "Termal conductivity indicates the ability of a material to conduct heat."@en ;
                         rdfs:label "thermal conductivity"@en ,
                                    "thermische geleidbaarheid"@nl .


