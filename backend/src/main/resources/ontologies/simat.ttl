                                                    rdfs:subClassOf <https://w3id.org/simat/Metals> ;
                                                    om-2:alternativeLabel "Ti"@en ;
                                                    rdfs:comment """Titanium alloys are alloys that contain a mixture of titanium and other chemical elements. Such alloys have very high tensile strength and toughness (even at extreme temperatures). 
(https://en.wikipedia.org/wiki/Titanium_alloys)"""@en ;
                                                    rdfs:label "Titanium"@en .


###  https://w3id.org/simat/Tow
<https://w3id.org/simat/Tow> rdf:type owl:Class ;
                                               rdfs:subClassOf <https://w3id.org/simat/UnidirectionalReinforcement> ;
                                               rdfs:label "Tow"@en .


###  https://w3id.org/simat/TriaxialBraidedReinforcement
<https://w3id.org/simat/TriaxialBraidedReinforcement> rdf:type owl:Class ;
                                                                        rdfs:subClassOf <https://w3id.org/simat/BraidedTextile> ;
                                                                        rdfs:comment "Structure resulting from the interlacing of two yarn systems called braiding yarns around an axial yarn system into a textile."@en ;
                                                                        rdfs:label "Triaxial braided reinforcement"@en .


###  https://w3id.org/simat/Tube
<https://w3id.org/simat/Tube> rdf:type owl:Class ;
                                                rdfs:subClassOf <https://w3id.org/simat/Part> ;
                                                rdfs:comment "A long, hollow cylinder of material."@en ;
                                                rdfs:label "Tube"@en .


###  https://w3id.org/simat/TwillWeave
<https://w3id.org/simat/TwillWeave> rdf:type owl:Class ;
                                                      rdfs:subClassOf <https://w3id.org/simat/WovenTextile> ;
                                                      rdfs:comment """Twill is one of the most commonly used weave patterns in textile production. This type of weave creates a pattern of diagonal lines, or ribs, by passing the weft yarn under and over several warp yarns in an alternating pattern.
(https://jpscm.com/blog/types-of-weave-patterns/)"""@en ;
                                                      rdfs:label "Twill weave"@en .


###  https://w3id.org/simat/UltimateStrain
<https://w3id.org/simat/UltimateStrain> rdf:type owl:Class ;
                                                          rdfs:subClassOf <https://w3id.org/simat/FailureProperty> ,
                                                                          [ rdf:type owl:Restriction ;
                                                                            owl:onProperty om-2:hasValue ;
                                                                            owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty om-2:hasUnit ;
                                                                                                owl:allValuesFrom om-2:StrainUnit
                                                                                              ]
                                                                          ] ;
                                                          rdfs:comment "Mechanical property describing the deformation of material at the ultimate strength."@en ;
                                                          rdfs:label "Ultimate strain"@en .


###  https://w3id.org/simat/UltimateStrength
<https://w3id.org/simat/UltimateStrength> rdf:type owl:Class ;
                                                            rdfs:subClassOf <https://w3id.org/simat/FailureProperty> ,
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty om-2:hasValue ;
                                                                              owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                                  owl:onProperty om-2:hasUnit ;
                                                                                                  owl:allValuesFrom om-2:StressUnit
                                                                                                ]
                                                                            ] ;
                                                            rdfs:comment "Mechanical property describing the stress in a material at the point of maximal load-bearing capacity and before damaging or failure occurs."@en ;
                                                            rdfs:label "Ultimate strength"@en .


###  https://w3id.org/simat/UnidirectionalReinforcement
<https://w3id.org/simat/UnidirectionalReinforcement> rdf:type owl:Class ;
                                                                       rdfs:subClassOf <https://w3id.org/simat/Reinforcement> ;
                                                                       rdfs:comment "Reinforcement containing one fibre system mostly oriented in a single direction."@en .


###  https://w3id.org/simat/Viscosity
<https://w3id.org/simat/Viscosity> rdf:type owl:Class ;
                                                     rdfs:subClassOf <https://w3id.org/simat/IntensiveProperty> ,
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty om-2:hasValue ;
                                                                       owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                           owl:onProperty om-2:hasUnit ;
                                                                                           owl:allValuesFrom <https://w3id.org/simat/ViscosityUnit>
                                                                                         ]
                                                                     ] ;
                                                     rdfs:comment """Measure of a fluid's rate-dependent resistance to a change in shape or to movement of its neighboring portions relative to one another.
(https://en.wikipedia.org/wiki/Viscosity)"""@en ;
                                                     rdfs:label "Viscosity"@en .


###  https://w3id.org/simat/ViscosityUnit
<https://w3id.org/simat/ViscosityUnit> rdf:type owl:Class ;
                                                         rdfs:subClassOf om-2:Unit ;
                                                         rdfs:label "viscosity unit"@en .


###  https://w3id.org/simat/Volume
<https://w3id.org/simat/Volume> rdf:type owl:Class ;
                                                  rdfs:subClassOf <https://w3id.org/simat/ExtensiveProperty> ,
                                                                  [ rdf:type owl:Restriction ;
                                                                    owl:onProperty om-2:hasValue ;
                                                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                        owl:onProperty om-2:hasUnit ;
                                                                                        owl:allValuesFrom om-2:VolumeUnit
                                                                                      ]
                                                                  ] ;
                                                  rdfs:label "Volume"@en .


###  https://w3id.org/simat/VolumetricHeatCapacity
<https://w3id.org/simat/VolumetricHeatCapacity> rdf:type owl:Class ;
                                                                  rdfs:subClassOf <https://w3id.org/simat/ThermalProperty> ,
                                                                                  [ rdf:type owl:Restriction ;
                                                                                    owl:onProperty om-2:hasValue ;
                                                                                    owl:allValuesFrom [ rdf:type owl:Restriction ;
                                                                                                        owl:onProperty om-2:hasUnit ;
                                                                                                        owl:allValuesFrom <https://w3id.org/simat/VolumetricHeatCapacityUnit>
                                                                                                      ]
                                                                                  ] ;
                                                                  rdfs:comment """Capacity of a material is the heat capacity of a sample of the substance divided by the volume of the sample.
(https://en.wikipedia.org/wiki/Volumetric_heat_capacity)"""@en ;
                                                                  rdfs:label "Volumetric heat capacity"@en .


###  https://w3id.org/simat/VolumetricHeatCapacityUnit
<https://w3id.org/simat/VolumetricHeatCapacityUnit> rdf:type owl:Class ;
                                                                      rdfs:subClassOf om-2:Unit ;
                                                                      rdfs:label "volumetric heat capacity unit"@en .


###  https://w3id.org/simat/WaterJetCutting
