###  https://w3id.org/simat/CarbonFibre
<https://w3id.org/simat/CarbonFibre> rdf:type owl:Class ;
                                                       owl:equivalentClass [ owl:intersectionOf ( <https://w3id.org/simat/Fibre>
                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                    owl:onProperty <https://w3id.org/simat/has_material_behaviour> ;
                                                                                                    owl:allValuesFrom <https://w3id.org/simat/OrthotropicMaterialBehaviour>
                                                                                                  ]
                                                                                                ) ;
