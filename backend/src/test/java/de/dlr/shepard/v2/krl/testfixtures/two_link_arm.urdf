<?xml version="1.0"?>
<!--
  Minimal two-link URDF fixture for KRL-INTERPRETER-05 service tests.
  The backend treats this as opaque bytes; the sidecar's ikpy-backed
  IK solver parses it. Two REVOLUTE joints + a TCP link give the
  minimum chain shape that exercises joint_0 / joint_1 channels.
-->
<robot name="two_link_arm">
  <link name="base_link"/>
  <link name="link_1"/>
  <link name="tool0"/>

  <joint name="joint_0" type="revolute">
    <parent link="base_link"/>
    <child link="link_1"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="2.0"/>
  </joint>

  <joint name="joint_1" type="revolute">
    <parent link="link_1"/>
    <child link="tool0"/>
    <origin xyz="0 0 0.2" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14" upper="3.14" effort="100" velocity="2.0"/>
  </joint>
</robot>
