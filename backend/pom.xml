        </configuration>
      </plugin>
      <plugin>
        <groupId>org.jacoco</groupId>
        <artifactId>jacoco-maven-plugin</artifactId>
        <reportSets>
          <reportSet>
            <reports>
              <!-- select non-aggregate reports -->
              <report>report</report>
            </reports>
          </reportSet>
        </reportSets>
      </plugin>
      <plugin>
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-pmd-plugin</artifactId>
      </plugin>
      <plugin>
        <groupId>com.github.spotbugs</groupId>
        <artifactId>spotbugs-maven-plugin</artifactId>
        <configuration>
          <onlyAnalyze>de.dlr.shepard.*</onlyAnalyze>
          <effort>Max</effort>
          <threshold>Low</threshold>
          <plugins>
            <plugin>
              <groupId>com.h3xstream.findsecbugs</groupId>
              <artifactId>findsecbugs-plugin</artifactId>
              <version>1.14.0</version>
            </plugin>
          </plugins>
        </configuration>
      </plugin>
    </plugins>
  </reporting>
  <profiles>
    <profile>
      <id>dev</id>
      <activation>
        <activeByDefault>true</activeByDefault>
      </activation>
      <properties>
        <build.profile.id>dev</build.profile.id>
        <logging.appender>STDOUT</logging.appender>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <profile>
      <id>prod</id>
      <properties>
        <build.profile.id>prod</build.profile.id>
        <logging.appender>FILE</logging.appender>
        <skipTests>true</skipTests>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <profile>
      <id>unit-test</id>
      <properties>
        <build.profile.id>test</build.profile.id>
        <quarkus.profile>test</quarkus.profile>
        <logging.appender>STDOUT</logging.appender>
        <skipITs>true</skipITs>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <profile>
      <id>migration-test</id>
      <properties>
        <build.profile.id>test</build.profile.id>
        <quarkus.profile>test</quarkus.profile>
        <logging.appender>STDOUT</logging.appender>
        <skipITs>true</skipITs>
        <include-in-unit-tests>${migrations-dir}</include-in-unit-tests>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <profile>
      <id>integration</id>
      <properties>
        <build.profile.id>integration</build.profile.id>
        <quarkus.profile>test</quarkus.profile>
        <logging.appender>STDOUT</logging.appender>
        <skipUTs>true</skipUTs>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <profile>
      <id>skip-test</id>
      <properties>
        <build.profile.id>test</build.profile.id>
        <quarkus.profile>test</quarkus.profile>
        <logging.appender>STDOUT</logging.appender>
        <skipITs>true</skipITs>
        <skipUTs>true</skipUTs>
        <quarkus.native.enabled>false</quarkus.native.enabled>
      </properties>
    </profile>
    <!--
      PM1a phase 3 (ADR-0023) — the `with-plugins` profile wires the
      in-tree `shepard-plugin-*` modules onto the backend's build
      classpath. Active **by default** so normal `mvn package` runs
      pull the plugin in (matching the operator-facing build flow).

      To bootstrap the local Maven repo for the first plugin build,
      pass `-DnoPlugins` to skip this profile and produce a
      backend.jar that the plugin can compile its `provided`-scope
      backend dep against:

        $ cd backend && mvn -DnoPlugins -DskipTests -Dquarkus.build.skip=true install
        $ cd plugins/unhide && mvn -DskipTests install
        $ cd backend && mvn package          # plugin is on the classpath

      CI does the same dance in `.github/workflows/backend-ci.yml` +
      `build-images.yml`; the developer runbook is mirrored in
      `docs/reference/plugins.md`.
    -->
    <profile>
      <id>with-plugins</id>
      <activation>
        <property>
          <name>!noPlugins</name>
        </property>
      </activation>
      <dependencies>
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-unhide</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          KIP1g — the Helmholtz Kernel Information Profile resolver
          + record shape extracted from the backend into a drop-in
          JAR. Same `with-plugins` profile pattern as UH1a: the
          plugin's `KipResolverRest` `@Path` resource is picked up
          by Quarkus's build-time CDI scanner when the JAR is on
          the backend's compile-time classpath. Operators consuming
          the published image get the resolver "for free"; operators
          building their own backend image without this dep lose
          the resolver while the generic publish endpoint still
          works (the in-core `PublishRest` produces no longer
          dereferenceable `resolverUrl` field in that posture, but
          the freshly-minted PID is still returned).
          See aidocs/16 KIP1g + aidocs/66.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-kip</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          KIP1h — the legitimate-default Local PID minter
          (`shepard-plugin-minter-local`, the renamed pre-KIP1h
          in-core `MockMinter`). Same `with-plugins` profile
          pattern as UH1a + KIP1g: the plugin's `LocalMinter`
          `@ApplicationScoped` bean is picked up by Quarkus's
          build-time CDI scanner when the JAR is on the backend's
          compile-time classpath. Operators consuming the published
          image get a working local-minter "for free"; operators
          building their own backend image with `-DnoPlugins` get
          a clean 503 `publish.minter.not-installed` on the publish
          endpoint (the resolver still works against pre-existing
          rows).
          See aidocs/16 KIP1h + aidocs/66.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-minter-local</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          KIP1d — DataCite Fabrica DOI minter plugin. Same shape as
          minter-local (sibling under `plugins/minter-datacite/`). The
          plugin's `DataciteMinter` `@ApplicationScoped` bean +
          `DataciteAdminRest` `@Path` resource are picked up by
          Quarkus's build-time CDI scanner when this JAR is on the
          backend's compile-time classpath via the index-dependency
          block in `application.properties`. Activated when an
          operator sets `shepard.publish.minter=datacite` after
          configuring credentials via the admin REST / CLI.
          See aidocs/16 KIP1d + aidocs/66 §6.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-minter-datacite</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          KIP1c — ePIC handle service minter plugin. Same shape as
          minter-datacite (sibling under `plugins/minter-epic/`). The
          plugin's `EpicMinter` `@ApplicationScoped` bean +
          `EpicAdminRest` `@Path` resource are picked up by
          Quarkus's build-time CDI scanner when this JAR is on the
          backend's compile-time classpath via the index-dependency
          block in `application.properties`. Activated when an
          operator sets `shepard.publish.minter=epic` after
          configuring credentials and prefix via the admin REST / CLI.
          See aidocs/16 KIP1c.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-minter-epic</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          SPI1a — PostGIS spatial-data payload kind extracted from the
          backend into a drop-in plugin per the plugin-first heuristic
          #1 ("New payload kinds → plugin from day one", CLAUDE.md)
          and the PayloadKind SPI (aidocs/47 §2). The plugin's
          CDI beans (SpatialDataContainerService, SpatialDataPointRest,
          SpatialDataReferenceRest, etc.) are discovered by Quarkus's
          build-time CDI scanner when this JAR is on the backend's
          compile-time classpath. The SpatialPayloadKind class
          registers Neo4j-OGM entity packages via ServiceLoader in
          NeoConnector.connect().
          See aidocs/47 SPI1a.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-spatial</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          PL1c — HDF5/HSDS payload kind extracted from the backend
          into a drop-in plugin per the plugin-first heuristic #1
          ("New payload kinds → plugin from day one", CLAUDE.md)
          and the PayloadKind SPI (aidocs/47 §2). The plugin's
          CDI beans (HdfContainerService, HdfContainerRest,
          HdfAdminRest, HdfPermissionBridge, HsdsClient) are
          discovered by Quarkus's build-time CDI scanner when this
          JAR is on the backend's compile-time classpath. The
          HdfPayloadKind class registers Neo4j-OGM entity packages
          via ServiceLoader in NeoConnector.connect(), fixing the
          latent OGM-gap where HdfContainer was previously
          unregistered.
          See aidocs/47 PL1c.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-hdf5</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          PL1d — Git reference payload kind. Registers GitReference's
          Neo4j-OGM entity package via GitPayloadKind (PayloadKind SPI),
          fixes the latent OGM-gap where GitReference's package was
          previously unregistered in NeoConnector. GitCredential entity
          and service stay in backend (auth perimeter). Migrations V19,
          V20, V26 stay in backend.
          See aidocs/47 PL1d.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-git</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          FS1b — S3-compatible file storage adapter. Provides
          S3FileStorage implementing the FS1a FileStorage SPI via
          AWS SDK v2. Talks the generic S3 wire protocol; any
          S3-compatible endpoint works (Garage, AWS S3, MinIO, etc.).
          Activate by setting shepard.storage.provider=s3 +
          shepard.files.s3.* properties.
          See aidocs/45 FS1b.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-file-s3</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          AAS1-plugin — Asset Administration Shell integration
          extracted from the backend into a drop-in plugin per the
          plugin-first heuristic #2 ("New external integrations →
          plugin shape", CLAUDE.md). The plugin's CDI beans
          (AasShellsRest, AasWellKnownRest, AasAdminRest,
          AasRegistrationAdminRest, AasRegistryOutboxService, etc.)
          are discovered by Quarkus's build-time CDI scanner when
          this JAR is on the backend's compile-time classpath.
          V46 Neo4j migration stays in backend (Docker runner reads
          /deployments/neo4j/migrations, not plugin JAR resources).
          See aidocs/plugins/69.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-aas</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          VID1b — video payload kind plugin. VideoStreamReference entity,
          VideoAnnotationRest, VideoStreamReferenceV2Rest, VideoProbeService,
          and VideoAnnotationDAO live here. quarkus.index-dependency entry
          in application.properties ensures Quarkus/Arc indexes CDI beans
          from this JAR.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-video</artifactId>
          <version>${revision}</version>
        </dependency>
        <!--
          AT1 — timeseries-analytics plugin extracting the in-tree AI1b
          rolling-median MAD anomaly detector behind the
          `TimeseriesAnalytics` SPI (`de.dlr.shepard.spi.analytics`).
          Plugin's `MADDetector` `@ApplicationScoped` bean is discovered
          by Quarkus's build-time CDI scanner via the
          quarkus.index-dependency.shepard-plugin-analytics-ts.* entries
          in application.properties. AnalyticsRegistry picks the bean
          up on @Observes StartupEvent. Same with-plugins-profile
          shape as every other shepard-plugin-* module (ADR-0023).
          See plugins/analytics-ts/docs/reference.md.
        -->
        <dependency>
          <groupId>de.dlr.shepard.plugins</groupId>
          <artifactId>shepard-plugin-analytics-ts</artifactId>
          <version>${revision}</version>
        </dependency>
      </dependencies>
    </profile>
  </profiles>
</project>
