  </ciManagement>
  <properties>
    <finalName>shepard</finalName>
    <revision>6.0.0-SNAPSHOT</revision>
    <skipTests>false</skipTests>
    <!-- Skip integration tests. The tests will populate the databases with values. -->
    <skipITs>${skipTests}</skipITs>
    <!-- Skip "unit" tests. Most of them will populate the databases with values. -->
    <skipUTs>${skipTests}</skipUTs>
    <!-- Coverage gate. Default off so a developer's local `mvn verify` doesn't
         error on a partial run; CI passes -Djacoco.haltOnFailure=true. -->
    <jacoco.haltOnFailure>false</jacoco.haltOnFailure>
    <!-- SpotBugs/findsecbugs gate. Same off-by-default-locally / on-in-CI
         shape — CI passes -Dspotbugs.failOnError=true. -->
    <spotbugs.failOnError>false</spotbugs.failOnError>
    <!-- The directory glob in which the migration tests reside. -->
    <migrations-dir>**/migrations/**</migrations-dir>
    <!--
      Default tests to include in the "unit" test suite.
      Migrations must be tested separately since they rely on fresh databases.
      Therefore, they are excluded by default.
    -->
    <include-in-unit-tests>!${migrations-dir}</include-in-unit-tests>
