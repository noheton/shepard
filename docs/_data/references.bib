  howpublished = {VAM-HRI 2018 workshop paper, ACM},
  note         = {VAM-HRI 2018 workshop paper by Sch{\"o}nheits and Krebs, both DLR Institute of Structures and Design, ZLP Augsburg. Six-page demonstrator paper describing an industrial HRI testbed built around a KUKA KR120 Quantec extra HA robot, Microsoft HoloLens, Pozyx UWB-RTLS, V-REP co-simulation, and OPC-UA middleware. Documents (i) a multi-modal HoloLens calibration process with three steps -- tap-gesture select, gaze-driven HUD manipulation, speech-command confirmation (``calibration done'') -- summarised in Table~1, and (ii) an interactive speech-driven robot control scheme with four commands (``Stop'', ``Look at me'', ``Come here'', ``Go home'') mapped as a pseudo-state machine (Figure~13). Safety frame: ISO 10218 + ISO/TS 15066; demo ran in manual mode with a separate dead-man operator. The 2018 anchor of an HRI research line the institute has continued through IROS 2018 Fan Challenge (Schoenheits, YouTube \texttt{hJxTF9RISIw}), DrapeBot 2023--2024 (YouTube \texttt{nao1U3IB20k, 4CBZNBolAAE, r2pG1Lg393c}), and is documented as a deliberate 2017--2024 strategic research line in \texttt{aidocs/strategy/102} \S 4. Filed under \texttt{/root/.claude/uploads/33f9b6cd-283e-4eb5-bfea-fec7b3720743/a272d6be-VAMHRI2018\_paper\_17.pdf}.},
  category     = {peer_reviewed}
}

@misc{dlrSchoenheitsKrebsHriWorkshop2017,
  author       = {Sch{\"o}nheits, Manfred and Krebs, Florian},
  title        = {{Robotics: Human-Robot-Interaction (Workshop DLR@UBC, 06.12.17--08.12.17)}},
  year         = {2017},
  month        = dec,
  howpublished = {Presentation slides, DLR@UBC workshop, University of British Columbia, Vancouver, 6--8 December 2017},
  note         = {12-slide deck on the same robot-cell testbed that becomes the VAM-HRI 2018 paper (\texttt{dlrSchoenheitsVamhri2018}) three months later. Slide~1 dates the talk explicitly: ``Workshop DLR@UBC 06.12.17 -- 08.12.17''. Slide~3 (Objectives): ``Applying HRI concepts for (big) industrial robots'' and ``Create basis / starting point for future work''. Slides~4--7 introduce the four core concepts: UWB localisation (Pozyx), Augmented Reality (Hololens), OPC-UA, V-REP co-simulation. Slide~10 emphasises a peer-to-peer distributed-system stance: ``No master or central node $\ne$ ROS running master control logic''. Slide~11 lists the same four voice commands (``Stop'', ``Look at me'', ``Come here'', ``Go home'') and notes the safety-critical convention ``Stop command is always required to proceed''. Slide~12 (Future work): ``multi-laser sensor setup'', ``expansion to large scale scenarios'', ``automatic collision-free path planning''. \textbf{Chronological observation:} this presentation was given on the same day as \texttt{20171205\_Vision\_Datenmanagement.pptx} (prior batch) -- DLR@UBC 2017-12-05 produced both the institute's HRI demo \emph{and} the institute's data-management vision presentation. Filed under \texttt{/root/.claude/uploads/33f9b6cd-283e-4eb5-bfea-fec7b3720743/7b074b7f-20171205\_Workshop\_HRI\_Demo.pptx}. Accessed 2026-05-23.},
  category     = {dlr_internal}
}

