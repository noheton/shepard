{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchPackageNames": ["node", "@types/node"],
      "groupName": "Node.js",
      "versioning": "node"
    },
    {
      "matchPackageNames": ["vue"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["vue-router"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["vuex"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["bootstrap"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["portal-vue"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["typescript"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["@vue/tsconfig"],
      "allowedVersions": "<0.2"
    },
    {
      "matchPackageNames": ["eslint"],
      "allowedVersions": "<9"
    },
    {
      "matchSourceUrls": ["https://github.com/vuejs/language-tools"],
      "groupName": "language-tools monorepo"
    },
    {
      "matchSourceUrlPrefixes": ["https://github.com/retejs"],
      "groupName": "retejs organization"
    },
    {
      "matchSourceUrls": ["https://github.com/ueberdosis/tiptap"],
      "groupName": "tiptap monorepo"
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0
}
