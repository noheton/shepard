{
  "name": "shepard-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check build-only",
    "preview": "vite preview --port 4173",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --ignore-path .gitignore",
    "fix": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "client-codegen": "rimraf src/generated/openapi && npm run update-openapi-spec && openapi-generator-cli generate -g typescript-fetch -o src/generated/openapi -p=supportsES6=true,typescriptThreePlus=true -i src/generated/openapi-source/openapi.json",
    "update-openapi-spec": "curl --output-dir src/generated/openapi-source -o openapi.json http://localhost:8080/shepard/doc/openapi.json"
  },
  "dependencies": {
    "@dlr-shepard/backend-client": "file:../backend-client",
    "@tiptap/extension-text-align": "2.11.7",
    "@tiptap/extension-underline": "2.11.7",
    "@tiptap/pm": "2.11.7",
    "@tiptap/starter-kit": "2.11.7",
    "@tiptap/vue-2": "2.11.7",
    "@vueuse/core": "11.3.0",
    "bootstrap": "4.6.2",
    "bootstrap-vue": "2.23.1",
    "chart.js": "4.4.9",
    "csv-parse": "5.6.0",
    "jsoneditor": "10.2.0",
    "loglevel": "1.9.2",
    "nanoid": "5.1.5",
    "oidc-client-ts": "3.2.0",
    "popper.js": "1.16.1",
    "portal-vue": "2.1.7",
    "rete": "2.0.5",
    "rete-area-plugin": "2.1.3",
    "rete-auto-arrange-plugin": "2.0.2",
    "rete-connection-plugin": "2.0.5",
    "rete-context-menu-plugin": "2.0.6",
    "rete-engine": "2.1.1",
    "rete-render-utils": "2.0.3",
    "rete-vue-plugin": "2.1.1",
    "rete-vue-render-plugin": "0.5.2",
    "vis-network": "9.1.9",
    "vue": "2.7.16",
    "vue-chartjs": "5.3.2",
    "vue-router": "3.6.5",
    "vue2-helpers": "2.1.1",
    "vuex": "3.6.2",
    "vuex-oidc": "4.0.2"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "2.19.1",
    "@rushstack/eslint-patch": "1.11.0",
    "@tsconfig/node20": "20.1.5",
    "@types/chart.js": "2.9.41",
    "@types/jsoneditor": "9.9.5",
    "@types/node": "22.14.1",
    "@vitejs/plugin-vue2": "2.3.3",
    "@volar/vue-typescript": "1.6.5",
    "@vue/eslint-config-prettier": "9.0.0",
    "@vue/eslint-config-typescript": "13.0.0",
    "@vue/tsconfig": "0.1.3",
    "eslint": "8.57.1",
    "eslint-plugin-vue": "9.33.0",
    "npm-run-all2": "7.0.2",
    "prettier-plugin-organize-imports": "3.2.4",
    "rimraf": "6.0.1",
    "sass": "1.87.0",
    "typescript": "4.9.5",
    "vite": "5.4.18",
    "vue-tsc": "2.0.22"
  }
}
