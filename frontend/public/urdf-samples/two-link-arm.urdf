<?xml version="1.0"?>
<!--
  two-link-arm.urdf — minimal sample URDF for the URDF viewer.

  Two revolute joints, three links built from primitive box geometries (no
  external mesh dependencies). Designed to render meaningfully in
  UrdfCanvas/UrdfView when no real URDF is bound, and to exercise joint
  sliders in UrdfJointPanel.
-->
<robot name="two_link_arm">

  <!-- Base / world fixture -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.025" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 0.2 0.05"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
  </link>

  <!-- Shoulder joint: revolute about Z (yaw) -->
  <joint name="shoulder" type="revolute">
    <parent link="base_link"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="10" velocity="2"/>
  </joint>

  <!-- Upper arm: extends in +X by 0.4 m -->
  <link name="upper_arm">
    <visual>
      <origin xyz="0.2 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.4 0.05 0.05"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.9 1"/>
      </material>
    </visual>
  </link>

  <!-- Elbow joint: revolute about Y (pitch) at the end of upper arm -->
  <joint name="elbow" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0.4 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="10" velocity="2"/>
  </joint>

  <!-- Forearm: extends in +X by 0.3 m -->
  <link name="forearm">
    <visual>
      <origin xyz="0.15 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.04 0.04"/>
      </geometry>
      <material name="orange">
        <color rgba="0.95 0.55 0.15 1"/>
      </material>
    </visual>
  </link>

</robot>
