# Insert the public key form keycloak here:
OIDC_PUBLIC=

OIDC_AUTHORITY="http://keycloak:8082/realms/master/"

# Frontend setup
LOCAL_FRONTEND_AUTH_ORIGIN="http://localhost:3000/api/auth"
LOCAL_BACKEND_API_URL="http://localhost:8080/shepard/api"

# Neo4j setup
NEO4J_USER="neo4j"
NEO4J_PW="shepardshepard"

# MongoDB Setup
MONGO_ROOT_USERNAME="mongo"
MONGO_ROOT_PASSWORD="secret"

MONGO_DATABASE="database"
MONGO_USERNAME="mongo_user"
MONGO_PASSWORD="secret"

# Grafana Setup
GRAFANA_ADMIN_USERNAME="shepard"
GRAFANA_ADMIN_PASSWORD="secret"

# Postgres Setup
POSTGRES_DB="postgres"
## These are the credentials for the postgres admin account
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
## These are the credentials for the shepard user account
POSTGRES_SHEPARD_USER="shepard"
POSTGRES_SHEPARD_USER_PW="shepard_secret"

SHEPARD_MIGRATION_MODE_ENABLED="false"

# Enable automatic conversion of integer values to double for time series with type double.
# For more information see https://gitlab.com/dlr-shepard/shepard/-/merge_requests/717
SHEPARD_AUTOCONVERT_INT="true"

# Configure docker profiles to enable experimental features
COMPOSE_PROFILES="tryout"
