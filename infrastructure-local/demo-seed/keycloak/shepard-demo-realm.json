{
  "realm": "shepard-demo",
  "enabled": true,
  "displayName": "shepard — demo realm",
  "displayNameHtml": "<strong>shepard</strong> demo realm",
  "registrationAllowed": false,
  "resetPasswordAllowed": false,
  "rememberMe": true,
  "verifyEmail": false,
  "loginWithEmailAllowed": false,
  "duplicateEmailsAllowed": false,
  "sslRequired": "none",
  "accessTokenLifespan": 3600,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "users": [
    {
      "username": "alice",
      "firstName": "Alice",
      "lastName": "Researcher",
      "email": "alice@demo.shepard.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "alice-demo",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "bob",
      "firstName": "Bob",
      "lastName": "Reviewer",
      "email": "bob@demo.shepard.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "bob-demo",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    },
    {
      "username": "admin",
      "firstName": "Demo",
      "lastName": "Admin",
      "email": "admin@demo.shepard.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin-demo",
          "temporary": false
        }
      ],
      "realmRoles": ["user", "instance-admin"]
    },
    {
      "username": "harvester",
      "firstName": "Demo",
      "lastName": "Harvester",
      "email": "harvester@demo.shepard.local",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "harvester-demo",
          "temporary": false
        }
      ],
      "realmRoles": ["user"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "user",
        "description": "Standard logged-in shepard user"
      },
      {
        "name": "instance-admin",
        "description": "Demo instance-admin role; maps to shepard's instance-admin via the OIDC role claim"
      }
    ]
  },
  "clients": [
    {
      "clientId": "frontend-dev",
      "name": "shepard demo frontend",
      "description": "Demo public client used by the Vue/Nuxt frontend",
      "rootUrl": "http://localhost:3000",
      "baseUrl": "/",
      "enabled": true,
      "publicClient": true,
      "redirectUris": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "webOrigins": [
        "http://localhost:3000",
        "http://127.0.0.1:3000"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "implicitFlowEnabled": false,
      "frontchannelLogout": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": ["web-origins", "acr", "profile", "roles", "basic", "email"],
      "optionalClientScopes": ["address", "phone", "offline_access", "microprofile-jwt"],
      "attributes": {
        "post.logout.redirect.uris": "+",
        "pkce.code.challenge.method": "S256"
      }
    },
    {
      "clientId": "shepard-backend",
      "name": "shepard demo backend",
      "description": "Demo backend confidential client (resource-server posture)",
      "enabled": true,
      "publicClient": false,
      "bearerOnly": true,
      "secret": "demo-backend-client-secret-not-for-prod",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "implicitFlowEnabled": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true
    }
  ],
  "defaultRoles": ["user"],
  "smtpServer": {}
}
