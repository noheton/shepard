<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE xml>
<configuration>

	<appender name="appender"
		class="ch.qos.logback.core.ConsoleAppender">
		<encoder>
			<pattern>[%-5level] %logger{15} - %msg%n</pattern>
		</encoder>
	</appender>

	<root level="info">
		<appender-ref ref="appender" />
	</root>
</configuration>
