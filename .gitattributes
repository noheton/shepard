* text eol=lf

# Declare files that will always have CRLF line endings on checkout.
*.bat eol=crlf
*.cmd eol=crlf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.ico binary
*.ttf binary

# Reference HTM dumps (DLR CD-Handbuch theme references) — leave bytes
# untouched so they don't keep showing as modified under eol=lf.
aidocs/input/*.htm -text
