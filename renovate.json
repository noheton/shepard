{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "baseBranches": ["develop"],
  "osvVulnerabilityAlerts": true,
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchCategories": ["ci"],
      "groupName": "ci dependencies"
    },
    {
      "matchManagers": ["docker-compose"],
      "groupName": "infrastructure dependencies"
    },
    {
      "matchPackageNames": ["influxdb", "neo4j", "mongo"],
      "matchManagers": ["gitlabci"],
      "groupName": "infrastructure dependencies"
    },
    {
      "matchFileNames": ["quarkend/**"],
      "matchManagers": ["dockerfile"],
      "groupName": "quarkus docker"
    },
    {
      "matchPackageNames": ["node", "@types/node"],
      "groupName": "Node.js",
      "versioning": "node"
    },
    {
      "matchPackagePrefixes": ["io.swagger.core.v3"],
      "groupName": "swagger"
    },
    {
      "matchPackageNames": ["openapitools/openapi-generator-cli"],
      "groupName": "openapi-generator"
    },
    {
      "matchSourceUrls": ["https://github.com/vuejs/language-tools"],
      "groupName": "language-tools monorepo"
    },
    {
      "matchSourceUrlPrefixes": ["https://github.com/retejs"],
      "groupName": "retejs organization"
    },
    {
      "matchSourceUrls": ["https://github.com/ueberdosis/tiptap"],
      "groupName": "tiptap monorepo"
    },
    {
      "matchPackagePatterns": ["(@dlr-shepard/)?shepard-client"],
      "groupName": "shepard client"
    },
    {
      "matchPackagePatterns": ["(org.apache.tomcat:)?tomcat(-.+)?"],
      "groupName": "tomcat",
      "allowedVersions": "<11"
    },
    {
      "matchPackageNames": ["influxdb"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<2"
    },
    {
      "matchPackageNames": ["neo4j"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["mongo"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["vue"],
      "matchManagers": ["npm"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["vue-router"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["vuex"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["bootstrap"],
      "matchManagers": ["npm"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["portal-vue"],
      "matchManagers": ["npm"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["typescript"],
      "matchManagers": ["npm"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["@vue/tsconfig"],
      "matchManagers": ["npm"],
      "allowedVersions": "<0.2"
    },
    {
      "matchPackageNames": ["vue-tsc"],
      "matchManagers": ["npm"],
      "allowedVersions": "<2.0.24"
    },
    {
      "matchPackageNames": ["prettier-plugin-organize-imports"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchPackageNames": ["eslint"],
      "matchManagers": ["npm"],
      "allowedVersions": "<9"
    },
    {
      "matchPackagePrefixes": ["org.neo4j:neo4j-ogm"],
      "matchManagers": ["maven"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["openapitools/openapi-generator-cli"],
      "matchFileNames": [".gitlab/ci/clients/python-legacy.gitlab-ci.yml"],
      "allowedVersions": "<7"
    }
  ]
}
