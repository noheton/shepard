{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackageNames": ["influxdb"],
      "allowedVersions": "<2"
    },
    {
      "matchPackageNames": ["node"],
      "matchManagers": ["gitlabci"],
      "versioning": "node"
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true
}
