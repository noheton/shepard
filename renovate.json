{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackageNames": ["vue"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["vue-router"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["vuex"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["bootstrap"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["node", "@types/node"],
      "groupName": "Node.js"
    },
    {
      "matchSourceUrls": ["https://github.com/johnsoncodehk/volar"],
      "groupName": "Volar monorepo packages"
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0
}
