{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackageNames": ["neo4j"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["influxdb"],
      "allowedVersions": "<2",
      "matchFileNames": ["docker-compose.yml", ".gitlab-ci.yml"]
    },
    {
      "matchPackageNames": ["mongo"],
      "allowedVersions": "<5",
      "matchFileNames": ["docker-compose.yml", ".gitlab-ci.yml"]
    },
    {
      "matchPackageNames": ["openapitools/openapi-generator-cli"],
      "allowedVersions": "<7",
      "matchFileNames": [".gitlab/ci/python-legacy.gitlab-ci.yml"]
    },
    {
      "matchPackagePatterns": ["tomcat(-.+)?"],
      "groupName": "tomcat"
    },
    {
      "matchPackagePatterns": ["swagger(-.+)?"],
      "groupName": "swagger"
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0
}
