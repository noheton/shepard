{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["influxdb"],
      "allowedVersions": "<2"
    },
    {
      "matchPackageNames": ["neo4j"],
      "allowedVersions": "<5"
    }
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true
}
