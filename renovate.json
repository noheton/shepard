{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "packageRules": [
    {
      "matchPackageNames": ["influxdb"],
      "allowedVersions": "<2"
    },
    {
      "matchPackagePatterns": ["tomcat(-.+)?"],
      "groupName": "tomcat"
    }
  ],
  "prHourlyLimit": 0,
  "labels": ["dependencies"],
  "dependencyDashboard": true
}
