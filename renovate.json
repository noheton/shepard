{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "configMigration": true,
  "baseBranches": ["develop"],
  "osvVulnerabilityAlerts": true,
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "dependencyDashboardLabels": ["dependencies"],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "packageRules": [
    {
      "matchFileNames": ["package.json"],
      "groupName": "develop dependencies"
    },
    {
      "matchFileNames": [".gitlab-ci.yml", ".gitlab/ci/**"],
      "groupName": "develop dependencies"
    },
    {
      "matchFileNames": ["backend/**"],
      "groupName": "backend dependencies"
    },
    {
      "matchFileNames": ["backend/**"],
      "matchPackageNames": ["io.quarkus:quarkus-bom"],
      "groupName": "backend quarkus update",
      "prBody": "This pull request updates Quarkus to the latest version. We do not want to update to non-LTS versions of Quarkus. A list of current Quarkus releases can be found here [Quarkus releases](https://quarkus.io/blog/tag/release/)."
    },
    {
      "matchFileNames": ["frontend/**"],
      "groupName": "frontend dependencies"
    },
    {
      "matchFileNames": ["nuxtend/**"],
      "groupName": "nuxtend dependencies"
    },
    {
      "matchFileNames": ["infrastructure/**"],
      "groupName": "infrastructure dependencies"
    },
    {
      "matchFileNames": ["scripts/**"],
      "groupName": "scripts dependencies"
    },
    {
      "matchFileNames": ["backend/**", "frontend/**"],
      "matchManagers": ["dockerfile", "docker-compose"],
      "groupName": "develop dependencies"
    },
    {
      "matchPackageNames": ["influxdb", "neo4j", "mongo"],
      "matchManagers": ["gitlabci"],
      "groupName": "infrastructure dependencies"
    },
    {
      "matchPackageNames": ["/(@dlr-shepard/)?shepard-client/"],
      "groupName": "shepard client"
    },
    {
      "matchPackageNames": ["openapitools/openapi-generator-cli"],
      "groupName": "openapi generator"
    },
    {
      "matchPackageNames": ["influxdb"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<=1.8"
    },
    {
      "matchPackageNames": ["chronograf"],
      "matchManagers": ["docker-compose"],
      "allowedVersions": "<1.10"
    },
    {
      "matchPackageNames": ["neo4j"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["mongo"],
      "matchManagers": ["docker-compose", "gitlabci"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["vue"],
      "matchManagers": ["npm"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["vue-router"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["vuex"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["bootstrap"],
      "matchManagers": ["npm"],
      "allowedVersions": "<5",
      "enabled": false
    },
    {
      "matchPackageNames": ["portal-vue"],
      "matchManagers": ["npm"],
      "allowedVersions": "<3"
    },
    {
      "matchPackageNames": ["typescript"],
      "matchManagers": ["npm"],
      "allowedVersions": "<5"
    },
    {
      "matchPackageNames": ["node"],
      "matchManagers": ["gitlabci", "dockerfile"],
      "versionCompatibility": "^(?<version>[^-]+)(?<compatibility>-.*)?$",
      "versioning": "node"
    },
    {
      "matchPackageNames": ["@vue/tsconfig"],
      "matchManagers": ["npm"],
      "allowedVersions": "<0.2"
    },
    {
      "matchPackageNames": ["vue-tsc"],
      "matchManagers": ["npm"],
      "allowedVersions": "<2.0.24"
    },
    {
      "matchPackageNames": ["prettier-plugin-organize-imports"],
      "matchManagers": ["npm"],
      "allowedVersions": "<4.0.0"
    },
    {
      "matchPackageNames": ["eslint"],
      "matchManagers": ["npm"],
      "allowedVersions": "<9"
    },
    {
      "matchPackageNames": ["@vue/eslint-config-typescript"],
      "matchManagers": ["npm"],
      "allowedVersions": "<14"
    },
    {
      "matchPackageNames": ["@vue/eslint-config-prettier"],
      "matchManagers": ["npm"],
      "allowedVersions": "<10"
    },
    {
      "matchPackageNames": ["org.neo4j:neo4j-ogm{/,}**"],
      "matchManagers": ["maven"],
      "allowedVersions": "<4"
    },
    {
      "matchPackageNames": ["io.jsonwebtoken:jjwt{/,}**"],
      "matchManagers": ["maven"],
      "allowedVersions": "<0.12"
    },
    {
      "matchPackageNames": ["org.junit.jupiter:junit-jupiter{/,}**"],
      "matchManagers": ["maven"],
      "allowedVersions": "<5.11"
    },
    {
      "matchFileNames": ["frontend/**"],
      "matchPackageNames": ["@vueuse/core"],
      "allowedVersions": "<12"
    },
    {
      "matchFileNames": ["frontend/**"],
      "matchPackageNames": ["vite"],
      "allowedVersions": "<6"
    }
  ]
}
